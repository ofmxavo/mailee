# Supabase (public)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Public app URL used for auth redirects (set to your deployed domain)
NEXT_PUBLIC_SITE_URL=https://mailee-one.vercel.app

# Supabase (server only)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# AI provider (optional for current auth/dashboard flows)
OPENAI_API_KEY=your-openai-api-key

# Resend (server only)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxx

# Optional fallback sender used when inbox sender is not configured yet
MAIL_FROM_FALLBACK=concierge@yourdomain.com
